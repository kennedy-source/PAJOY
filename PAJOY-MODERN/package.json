{
  "name": "pajoy-system",
  "version": "2.0.0",
  "description": "PAJOY SYSTEM - Production-grade hybrid business platform for Kenyan retail",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:desktop\" \"npm run dev:web-admin\"",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:web-admin": "npm run dev --workspace=apps/web-admin",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "build:web-admin": "npm run build --workspace=apps/web-admin",
    "start": "npm run start --workspace=apps/backend",
    "test": "npm run test --workspaces",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "rimraf apps/*/dist apps/*/build packages/*/dist",
    "sync:db": "npm run migrate:local && npm run migrate:cloud",
    "migrate:local": "npm run migrate --workspace=databases/local-sqlite",
    "migrate:cloud": "npm run migrate --workspace=databases/cloud-postgres"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "PAJOY",
  "license": "UNLICENSED",
  "keywords": [
    "pos",
    "inventory",
    "kenya",
    "retail",
    "school-uniforms",
    "embroidery",
    "printing",
    "pesapal",
    "electron",
    "react",
    "typescript"
  ]
}
