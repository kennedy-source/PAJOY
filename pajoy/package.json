{
  "name": "pajoy-system",
  "version": "1.0.1",
  "description": "PAJOY SYSTEM - Offline-first POS, Inventory, School Uniforms, Embroidery & Printing for Kenyan retail",
  "main": "electron/main.js",
  "author": "PAJOY",
  "license": "UNLICENSED",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "nodemon --watch backend --exec node backend/server.js",
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:quick": "electron .",
    "build:frontend": "vite build",
    "build": "npm run build:frontend",
    "seed": "node scripts/seed.js",
    "start": "node backend/server.js",
    "start:backend": "node backend/server.js",
    "railway": "npm run start:backend",
    "desktop": "electron .",
    "start:web": "node backend/server.js & npm run dev:frontend",
    "start:electron": "npm run desktop",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:linux": "npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "nodemon": "^3.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.pajoy.uniforms.pos",
    "productName": "PAJOY Uniforms POS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "database/**/*",
      "scripts/**/*",
      "frontend/dist/**/*",
      "package.json",
      ".env.example"
    ],
    "extraResources": [
      {
        "from": "database",
        "to": "database"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PAJOY-Uniforms-POS-${version}.${ext}",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PAJOY-Uniforms-POS-${version}.${ext}",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PAJOY-Uniforms-POS-${version}.${ext}",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PAJOY Uniforms POS"
    },
    "publish": {
      "provider": "github",
      "owner": "pajoy-uniforms",
      "repo": "pajoy-pos"
    }
  }
}
