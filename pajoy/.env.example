# PAJOY POS System Environment Configuration

# Database Configuration
DB_PATH=./database/pajoy.db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pajoy_pos
DB_USER=postgres
DB_PASSWORD=password

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Desktop/local database configuration
PAJOY_DB_DIR=./database

# Pesapal Payment Gateway Configuration
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret_here
PESAPAL_BASE_URL=https://pay.pesapal.com/v3
PESAPAL_CALLBACK_URL=http://localhost:3000/api/pesapal/callback
PESAPAL_WEBHOOK_SECRET=your_webhook_secret_here

# Cloud database configuration (optional for future PostgreSQL migration)
DATABASE_URL=

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=8h

# Application Configuration
APP_NAME=PAJOY Uniforms POS
APP_VERSION=1.0.0
COMPANY_NAME=PAJOY Uniforms
COMPANY_ADDRESS=Nairobi, Kenya
COMPANY_PHONE=+254-XXX-XXX-XXX
COMPANY_EMAIL=info@pajoyuniforms.com

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Electron Configuration
ELECTRON_IS_DEV=true
ELECTRON_RENDERER_URL=http://localhost:5173
